<?xml version="1.0" encoding="UTF-8"?>
<syntax name="nsis">
    <meta>
        <name>NSIS</name>
        <type>script</type>
        <preferred-file-extension>nsi</preferred-file-extension>
    </meta>

    <detectors>
        <extension priority="1.0">nsi</extension>
        <extension priority="1.0">nsh</extension>
        <extension priority="0.8">bnsi</extension>
        <extension priority="0.8">bnsh</extension>
        <extension priority="0.8">nsdinc</extension>
    </detectors>

    <indentation>
        <increase>
            <expression>^\s*(?i)(Function|Section|SectionGroup|PageEx|!macro|!ifdef|!ifndef|!if|!ifmacrodef|!ifmacrondef)\b</expression>
        </increase>
        <decrease>
            <expression>^\s*(?i)(FunctionEnd|SectionEnd|SectionGroupEnd|PageExEnd|!macroend|!endif)\b</expression>
        </decrease>
    </indentation>

    <comments>
        <single>
            <expression>;</expression>
        </single>
        <single>
            <expression>#</expression>
        </single>
        <multiline>
            <starts-with>
                <expression>/\*</expression>
            </starts-with>
            <ends-with>
                <expression>\*/</expression>
            </ends-with>
        </multiline>
    </comments>

    <brackets>
        <pair open="(" close=")" />
        <pair open="{" close="}" />
        <pair open="[" close="]" />
    </brackets>

    <surrounding-pairs>
        <pair open="(" close=")" />
        <pair open="{" close="}" />
        <pair open="[" close="]" />
        <pair open="&quot;" close="&quot;" />
        <pair open="'" close="'" />
        <pair open="`" close="`" />
    </surrounding-pairs>

    <tree-sitter language="nsis">
        <highlights />
        <folds />
        <symbols />
    </tree-sitter>
</syntax>
